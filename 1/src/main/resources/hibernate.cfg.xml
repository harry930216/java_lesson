<?xml version="1.0" encoding="UTF-8"?>
<hibernate-configuration>
	<session-factory>
		<property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>  <!-- 用哪個 JDBC 驅動：MySQL 8 -->

		<property name="connection.url">jdbc:mysql://localhost:3306/harry</property>  <!-- 連本機 localhost、port 3306、資料庫名 harry -->

		<property name="connection.username">root</property>  <!-- DB 帳號 -->

		<property name="connection.password">root</property>  <!-- DB 密碼 -->

		
		<property name="hibernate.show_sql">true</property>  <!-- 把 Hibernate 實際送出的 SQL 印到主控台（學習期務必開）-->

		<property name="hibernate.format_sql">true</property>  <!-- 把印出來的 SQL 排版換行，不要擠成一行 -->

		<!-- ===== 自己看過：今天新增 entity 註冊（改用 XML 方式） ===== -->
		<!-- 每個 <mapping class="..."> = 告訴 Hibernate「這個類別是 entity，要對映成資料表」。 -->
		<!-- 這取代了 HibernateUtil.java 裡的 cfg.addAnnotatedClass(...)；兩者擇一即可，今天起統一用這裡。 -->
		<!-- 注意 package 是 tw.harry（你的），不是老師的 tw.brad。 -->
		<mapping class="tw.harry.entity.Test"></mapping>        <!-- 原本用程式碼註冊的 Test，搬到這裡 -->
		<mapping class="tw.harry.entity.Member"></mapping>      <!-- 今天新增：會員主檔 -->
		<mapping class="tw.harry.entity.MemberInfo"></mapping>  <!-- 今天新增：會員詳細資料（與 Member 共用主鍵） -->
		<mapping class="tw.harry.entity.Order"></mapping>       <!-- 一對多：訂單。這次登記了，因為 service 要實際跑 -->
		<mapping class="tw.harry.entity.OrderItem"></mapping>   <!-- 一對多：訂單品項 -->
		<mapping class="tw.harry.entity.Student"></mapping>     <!-- 多對多：學生（owner，定義 @JoinTable sc）-->
		<mapping class="tw.harry.entity.Course"></mapping>      <!-- 多對多：課程（inverse，mappedBy）-->
		<!-- 注意：join table sc 不是 entity、不登記 <mapping>，由 Student 的 @JoinTable 自動建 -->

	</session-factory>
</hibernate-configuration>

